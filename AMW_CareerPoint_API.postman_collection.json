{
  "info": {
    "name": "AMW Career Point API",
    "description": "Complete API collection for AMW Career Point — Frontend + Admin Panel\nBase URL: http://localhost:5000/api/v1\n\nHow to use:\n1. Import this file in Postman\n2. Run 'Admin - Login' first\n3. Copy the token from response\n4. It auto-saves to {{token}} variable\n5. All admin requests use {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "countryId", "value": "", "type": "string" },
    { "key": "universityId", "value": "", "type": "string" },
    { "key": "counsellorId", "value": "", "type": "string" },
    { "key": "reviewId", "value": "", "type": "string" },
    { "key": "blogId", "value": "", "type": "string" },
    { "key": "enquiryId", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 AUTH",
      "item": [
        {
          "name": "Admin - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('✅ Token saved:', res.data.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@amwcareerpoint.com\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Login and get JWT token. Token is auto-saved to {{token}} variable."
          }
        },
        {
          "name": "Admin - Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"PASTE_REFRESH_TOKEN_HERE\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Admin - Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },

    {
      "name": "🌍 COUNTRIES",
      "item": [
        {
          "name": "List Countries (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/countries?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["countries"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "featured", "value": "true", "disabled": true },
                { "key": "search", "value": "russia", "disabled": true },
                { "key": "sort", "value": "sortOrder", "disabled": true },
                { "key": "status", "value": "all", "disabled": true }
              ]
            },
            "description": "Public endpoint. Use ?featured=true for homepage. Use ?status=all for admin panel."
          }
        },
        {
          "name": "Get Country by Slug (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/countries/russia",
              "host": ["{{baseUrl}}"],
              "path": ["countries", "russia"]
            },
            "description": "Returns country detail + nested universities list"
          }
        },
        {
          "name": "Create Country (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('countryId', res.data.id);",
                  "  console.log('✅ Country ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Russia\",\n  \"countryCode\": \"ru\",\n  \"description\": \"Russia offers world-class medical education with globally recognized degrees at affordable costs. Russian medical universities are WHO and MCI approved.\",\n  \"bannerImage\": \"https://images.unsplash.com/photo-1547448415-e9f5b28e570d?w=1200\",\n  \"cardImage\": \"https://images.unsplash.com/photo-1547448415-e9f5b28e570d?w=400\",\n  \"headerColor\": \"#2563EB\",\n  \"feeRange\": \"₹2.5L – 6L\",\n  \"feeRangeUSD\": \"$4,000 - $6,000/year\",\n  \"duration\": \"6 Yrs\",\n  \"highlights\": [\"No IELTS\", \"WHO Approved\", \"Low Cost\"],\n  \"features\": [\n    \"WHO & NMC Approved Universities\",\n    \"No Entrance Exam Required\",\n    \"Affordable Tuition Fees\",\n    \"English Medium Courses\",\n    \"Global Recognition\"\n  ],\n  \"eligibility\": [\n    \"Minimum 50% in Physics, Chemistry, Biology\",\n    \"NEET Qualification Required\",\n    \"Age: 17-25 years\"\n  ],\n  \"admissionProcess\": [\n    { \"step\": 1, \"title\": \"Submit Application\", \"description\": \"Fill out the online application form with your academic details and documents.\" },\n    { \"step\": 2, \"title\": \"Document Verification\", \"description\": \"Our team verifies all submitted documents within 3-5 working days.\" },\n    { \"step\": 3, \"title\": \"Admission Letter\", \"description\": \"Receive official admission letter from the university.\" },\n    { \"step\": 4, \"title\": \"Visa Processing\", \"description\": \"Apply for student visa with our end-to-end visa assistance.\" },\n    { \"step\": 5, \"title\": \"Travel & Arrival\", \"description\": \"Travel to Russia with airport pickup and hostel arrangement.\" }\n  ],\n  \"climate\": \"Continental, -20°C to 30°C\",\n  \"language\": \"Russian (English medium available)\",\n  \"currency\": \"Russian Ruble (RUB)\",\n  \"livingCost\": \"₹15,000 – 25,000/month\",\n  \"visaInfo\": \"Student visa required, 30 days processing time\",\n  \"metaTitle\": \"MBBS in Russia 2026 – Fees, Top Universities, Admission\",\n  \"metaDescription\": \"Study MBBS in Russia from top WHO & NMC approved universities. Fees from ₹2.5L/year. No donation. Complete admission guidance by AMW Career Point.\",\n  \"isFeatured\": true,\n  \"sortOrder\": 1,\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/countries", "host": ["{{baseUrl}}"], "path": ["countries"] },
            "description": "Country ID is auto-saved to {{countryId}} for use in University creation"
          }
        },
        {
          "name": "Update Country (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isFeatured\": true,\n  \"sortOrder\": 1,\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/countries/{{countryId}}", "host": ["{{baseUrl}}"], "path": ["countries", "{{countryId}}"] },
            "description": "Send only the fields you want to update"
          }
        },
        {
          "name": "Reorder Countries (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"id\": \"COUNTRY_ID_1\", \"sortOrder\": 1 },\n    { \"id\": \"COUNTRY_ID_2\", \"sortOrder\": 2 },\n    { \"id\": \"COUNTRY_ID_3\", \"sortOrder\": 3 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/countries/reorder", "host": ["{{baseUrl}}"], "path": ["countries", "reorder"] }
          }
        },
        {
          "name": "Delete Country (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/countries/{{countryId}}", "host": ["{{baseUrl}}"], "path": ["countries", "{{countryId}}"] },
            "description": "Will fail if universities exist under this country"
          }
        }
      ]
    },

